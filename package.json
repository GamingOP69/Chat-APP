{
  "name": "chat-app-enterprise",
  "version": "1.0.0",
  "description": "Enterprise-grade real-time messaging platform with Socket.IO, PostgreSQL, Redis, and WebRTC.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js --exec node",
    "build": "node scripts/build.js",
    "test": "jest --runInBand tests/index.test.js",
    "lint": "eslint .",
    "bootstrap": "npm install",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "start:all": "sh ./start-all.sh"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "chat",
    "socket.io",
    "webrtc",
    "postgresql",
    "redis"
  ],
  "author": "GamingOP69",
  "license": "MIT",
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.8.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.2",
    "redis": "^4.7.1",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2"
  }
}
