# Runtime
NODE_ENV=development
PORT=3000
SOCKET_IO_PORT=3001
TRUST_PROXY=1

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=chat_app

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Socket.IO
SOCKET_IO_CORS_ORIGIN=http://localhost:3000
SOCKET_IO_ADAPTER=none

# JWT / sessions
JWT_SECRET=change-this-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_EXPIRES_IN=1h

# Google auth
GOOGLE_CLIENT_ID=

# Firebase Cloud Messaging
FIREBASE_SERVICE_ACCOUNT_JSON=

# S3 uploads (optional)
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Legacy S3 aliases kept for compatibility with older deployments
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# TURN server / WebRTC (optional)
# Example: [{"urls":["turn:turn.example.com:3478"],"username":"user","credential":"pass"}]
TURN_SERVERS=
TURN_EXTERNAL_IP=
TURN_USERS=

# Uploads / logging
MAX_FILE_SIZE=10485760
LOGGING_LEVEL=info
